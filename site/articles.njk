---
layout: base.njk
title: RAM Guides & Articles
description: Expert guides on choosing the best RAM for gaming, content creation, servers, and more. DDR5 vs DDR4 comparisons, overclocking tips, and buying advice.
---

<section class="articles-section">
  <div class="container">
    <div class="articles-hero">
      <h1 class="articles-title">RAM Guides & Articles</h1>
      <p class="articles-subtitle">Expert advice on choosing the right memory for your system — from gaming rigs to workstations and servers.</p>
    </div>
    
    <div class="articles-grid">
      {% for post in collections.posts %}
      <article class="article-card">
        <div class="article-image">
          <img src="{{ post.data.image | default('https://images.unsplash.com/photo-1562976540-1502c2145186?w=800&h=400&fit=crop') }}" alt="{{ post.data.title }}" loading="lazy">
        </div>
        <div class="article-content">
          <div class="article-meta">
            {% if post.data.categories[0] %}
            <span class="article-category">{{ post.data.categories[0] }}</span>
            {% endif %}
            <span class="article-date">{{ post.data.date | dateFormat }}</span>
          </div>
          <h2 class="article-title">
            <a href="{{ post.url }}">{{ post.data.title }}</a>
          </h2>
          <p class="article-excerpt">{{ post.data.description | default(post.templateContent | excerpt(150)) }}</p>
          <span class="article-read-more">
            Read Article
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"></line><polyline points="12 5 19 12 12 19"></polyline></svg>
          </span>
        </div>
      </article>
      {% endfor %}
    </div>
  </div>
</section>